# --- toolchains & environments (multi-GB, machine-local) ---
.venv/
toolchain/

# --- vendored dependencies (cloned separately, see vst/README) ---
vst/JUCE/
vst/rtaudio/

# --- build artifacts ---
*.exe
*.o
*.obj
vst/**/*.exe
*.zip
*.7z

# --- generated data / test dumps (regenerated by the tools) ---
*.f64
proto/*.wav
proto/*.png
vst/assets/*.f64
tank_ir_96k.f64
vst/renders/*.wav
vst/renders/probe.wav
vst/renders/*.json
# user-provided / commercial cab IRs — not ours to ship
vst/renders/ir/

# --- python cache ---
__pycache__/
*.pyc

# --- NAM-derived measurement caches (binary, regenerable, from private captures) ---
proto/_*.npy
proto/_*.npz
proto/_*.json
proto/sd1_cache/

# --- editor / os ---
.DS_Store
Thumbs.db

# --- machine-local Claude Code settings ---
.claude/settings.local.json
